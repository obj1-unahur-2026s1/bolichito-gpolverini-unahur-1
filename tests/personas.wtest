    }
    test "Given: placa (cobre) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(luisa.leGusta(placa))
    }
    test "Given: arito (cobre) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(luisa.leGusta(arito))
    }
    test "Given: banquito (madera) | When: consultamos leGusta() | Then: debería retornar false" {
