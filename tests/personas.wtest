import src.personas.*
import src.objetos.*
import src.colores.*

describe "Rosa | Preferencias: objetos de 2kg o menos" {
    test "Given: pelota (1300g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(pelota))
    }
    test "Given: remera (800g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(remera))
    }
    test "Given: biblioteca (8000g) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(rosa.leGusta(biblioteca))
    }
    test "Given: muñeco (200g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(muñeco))
    }
    test "Given: placa (200g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(placa))
    }
    test "Given: arito (180g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(arito))
    }
    test "Given: banquito (1700g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(banquito))
    }
    test "Given: cajita (580g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(rosa.leGusta(cajita))
    }
    test "Given: objeto con peso exacto 2000g | When: consultamos leGusta() | Then: debería retornar true" {
        muñeco.peso(2000)
        assert.that(rosa.leGusta(muñeco))
    }
    test "Given: objeto con peso 2001g | When: consultamos leGusta() | Then: debería retornar false" {
        muñeco.peso(2001)
        assert.notThat(rosa.leGusta(muñeco))
    }
}

describe "Estefanía | Preferencias: objetos de colores fuertes" {
    test "Given: pelota (parda) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(estefania.leGusta(pelota))
    }
    test "Given: remera (roja) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(estefania.leGusta(remera))
    }
    test "Given: biblioteca (verde) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(estefania.leGusta(biblioteca))
    }
    test "Given: muñeco (celeste) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(estefania.leGusta(muñeco))
    }
    test "Given: placa (roja) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(estefania.leGusta(placa))
    }
    test "Given: arito (celeste) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(estefania.leGusta(arito))
    }
    test "Given: banquito (naranja) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(estefania.leGusta(banquito))
    }
    test "Given: cajita (roja) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(estefania.leGusta(cajita))
    }
}

describe "Luisa | Preferencias: objetos de materiales brillantes" {
