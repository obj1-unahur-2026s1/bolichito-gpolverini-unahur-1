    }
    test "Given: cajita (cobre) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(luisa.leGusta(cajita))
    }
}

describe "Juan | Preferencias: colores no fuertes O peso entre 1200-1800g" {
    test "Given: pelota (parda, 1300g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(juan.leGusta(pelota))
    }
    test "Given: remera (roja, 800g) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(juan.leGusta(remera))
    }
    test "Given: biblioteca (verde, 8000g) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(juan.leGusta(biblioteca))
    }
    test "Given: muñeco (celeste) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(juan.leGusta(muñeco))
    }
    test "Given: placa (roja, 200g) | When: consultamos leGusta() | Then: debería retornar false" {
        assert.notThat(juan.leGusta(placa))
    }
    test "Given: arito (celeste) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(juan.leGusta(arito))
    }
    test "Given: banquito (1700g) | When: consultamos leGusta() | Then: debería retornar true" {
        assert.that(juan.leGusta(banquito))
    }
    test "Given: objeto con peso exacto 1200g y color fuerte | When: consultamos leGusta() | Then: debería retornar true" {
        placa.peso(1200)
        placa.color(rojo)
        assert.that(juan.leGusta(placa))
    }
    test "Given: objeto con peso exacto 1800g y color fuerte | When: consultamos leGusta() | Then: debería retornar true" {
        placa.peso(1800)
        placa.color(verde)
        assert.that(juan.leGusta(placa))
    }
    test "Given: objeto con peso 1199g y color fuerte | When: consultamos leGusta() | Then: debería retornar false" {
        placa.peso(1199)
        placa.color(rojo)
        assert.notThat(juan.leGusta(placa))
    }
    test "Given: objeto con peso 1801g y color fuerte | When: consultamos leGusta() | Then: debería retornar false" {
        placa.peso(1801)
        placa.color(verde)
        assert.notThat(juan.leGusta(placa))
    }
}