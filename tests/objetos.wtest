describe "Objeto | Verificar cambios de estado mutable" {
    test "Given: muñeco | When: cambiamos peso a 500 | Then: debería retornar 500" {
        muñeco.peso(500)
        assert.equals(500, muñeco.peso())
    }
    test "Given: placa | When: cambiamos color a verde | Then: debería retornar verde" {
        placa.color(verde)
        assert.equals(verde, placa.color())
    }
    test "Given: placa | When: cambiamos peso a 1500 | Then: debería retornar 1500" {
        placa.peso(1500)
        assert.equals(1500, placa.peso())
    }
    test "Given: banquito | When: cambiamos color a celeste | Then: debería retornar celeste" {
        banquito.color(celeste)
        assert.equals(celeste, banquito.color())
    }
    test "Given: cajita | When: cambiamos contenido a remera | Then: peso debería ser 1200g" {
        cajita.contenido(remera)
        assert.equals(1200, cajita.peso())
    }
    test "Given: cajita | When: cambiamos contenido a biblioteca | Then: peso debería ser 8400g" {
        cajita.contenido(biblioteca)
        assert.equals(8400, cajita.peso())
    }
}