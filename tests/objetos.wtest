import src.objetos.*
import src.colores.*
import src.materiales.*

describe "Objeto | Verificar propiedades de pelota" {
    test "Given: pelota | When: consultamos material, color y peso | Then: debería ser cuero, pardo y 1300g" {
        assert.equals(cuero, pelota.material())
        assert.equals(pardo, pelota.color())
        assert.equals(1300, pelota.peso())
    }
    test "Given: pelota | When: consultamos brilla() | Then: debería retornar false porque es de cuero" {
        assert.notThat(pelota.brilla())
    }
}

describe "Objeto | Verificar propiedades de remera" {
    test "Given: remera | When: consultamos material, color y peso | Then: debería ser lino, roja y 800g" {
        assert.equals(lino, remera.material())
        assert.equals(rojo, remera.color())
        assert.equals(800, remera.peso())
    }
    test "Given: remera | When: consultamos brilla() | Then: debería retornar false porque es de lino" {
        assert.notThat(remera.brilla())
    }
}

