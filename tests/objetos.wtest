describe "Objeto | Verificar propiedades de cajita" {
    test "Given: cajita | When: consultamos material, color y peso | Then: debería ser cobre, roja y 580g con arito adentro" {
        assert.equals(cobre, cajita.material())
        assert.equals(rojo, cajita.color())
        assert.equals(580, cajita.peso())
    }
    test "Given: cajita | When: consultamos brilla() | Then: debería retornar true porque es de cobre" {
